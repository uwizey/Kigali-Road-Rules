@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap');

:root {
    /* Colors */
    --primary: #0097b2;
    --primary-dark: #00bcd4;
    --green: #00D26A;
    --green-dark: #00a854;
    --bg-light: #F8FAFC;
    --black: #0F172A;
    --gray: #64748B;
    --gray-dark: #334155;
    --gray-light: #F1F5F9;
    --white: #FFFFFF;
    --border: #E2E8F0;
    
    /* Utils */
    --radius: 6px;
    --radius-lg: 20px;
    --radius-full: 100px;
    --shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    --shadow-lg: 0 10px 25px rgba(0, 0, 0, 0.1);
    --speed: 0.3s;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Plus Jakarta Sans', sans-serif;
}

html {
    scroll-behavior: smooth;
}

body {
    background-color: var(--bg-light);
    color: var(--black);
    line-height: 1.6;
    overflow-x: hidden;
}

/* ========== HEADER ========== */
.header {
    display: flex;
    align-items: center;
    padding: 8px 8%;
    width: 100%;
    top: 0;
    z-index: 1000;
    border-bottom: 1px solid var(--border);
    transition: var(--speed);
    background: rgb(240, 247, 255);
}

.header.hide {
    transform: translateY(-100%);
}

.header.scrolled {
    background: rgba(240, 247, 255, 0.95);
    backdrop-filter: blur(14px);
    box-shadow: var(--shadow);
}

.logo {
    width: 70px;
    height: 70px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--speed);
}

.logo img {
    max-height: 60px;
}

.logo:hover {
    transform: scale(1.05);
}

.site-name {
    font-size: 22px;
    font-weight: 700;
    color: var(--black);
    margin-left: 14px;
    line-height: 1.1;
}

.site-name span {
    color: var(--primary);
}

.links {
    display: flex;
    align-items: center;
    gap: 35px;
    margin-left: auto;
}

.login {
    background: linear-gradient(135deg, var(--primary-dark), var(--primary));
    padding: 10px 32px;
    border-radius: var(--radius);
    font-weight: 600;
    color: var(--white) !important;
    box-shadow: var(--shadow);
    transition: var(--speed);
    text-decoration: none;
    font-size: 14px;
}

.login:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    opacity: 0.95;
}

/* ========== MAIN CONTENT ========== */
.main-content {
    display: flex;
    flex-wrap: wrap;
    padding: 40px 8% 30px;
    gap: 50px;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
    min-height: calc(100vh - 200px);
}

/* ========== INTRO MESSAGE ========== */
.intro-msg-container {
    flex: 1;
    min-width: 400px;
}

.intro-msg-container h1 {
    font-size: clamp(36px, 5vw, 56px);
    color: var(--black);
    margin-bottom: 20px;
    line-height: 1.2;
    font-weight: 800;
    animation: fadeIn 0.6s ease;
}

.intro-msg-container h1 .highlight {
    color: var(--primary);
}

.intro-msg-container h1 .highlight-green {
    color: var(--green);
}

.intro-msg-container .description {
    font-size: 17px;
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 30px;
    max-width: 550px;
    animation: fadeIn 0.6s ease 0.1s both;
}

/* ========== BUTTONS ========== */
.button-container {
    display: flex;
    gap: 18px;
    margin-bottom: 35px;
    animation: fadeIn 0.6s ease 0.2s both;
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: var(--white);
    padding: 16px 40px;
    border-radius: var(--radius);
    font-size: 16px;
    font-weight: 700;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: var(--shadow);
    transition: var(--speed);
}

.btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
}

.btn-primary svg {
    width: 20px;
    height: 20px;
}

/* ========== STATS ========== */
.stats-container {
    display: flex;
    gap: 40px;
    padding-top: 30px;
    border-top: 1px solid var(--border);
    animation: fadeIn 0.6s ease 0.3s both;
}

.stat-item {
    text-align: left;
}

.stat-number {
    font-size: 32px;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 4px;
}

.stat-label {
    font-size: 13px;
    color: var(--gray);
    font-weight: 500;
}

/* ========== SCROLL ANIMATIONS ========== */
.scroll-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s ease, transform 0.8s ease;
}

.scroll-reveal.revealed {
    opacity: 1;
    transform: translateY(0);
}

.scroll-reveal-left {
    opacity: 0;
    transform: translateX(-60px);
    transition: opacity 0.8s ease, transform 0.8s ease;
}

.scroll-reveal-left.revealed {
    opacity: 1;
    transform: translateX(0);
}

.scroll-reveal-right {
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.8s ease, transform 0.8s ease;
}

.scroll-reveal-right.revealed {
    opacity: 1;
    transform: translateX(0);
}

.scroll-reveal-scale {
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.8s ease, transform 0.8s ease;
}

.scroll-reveal-scale.revealed {
    opacity: 1;
    transform: scale(1);
}

.scroll-delay-1 { transition-delay: 0.1s; }
.scroll-delay-2 { transition-delay: 0.2s; }
.scroll-delay-3 { transition-delay: 0.3s; }
.scroll-delay-4 { transition-delay: 0.4s; }
.scroll-delay-5 { transition-delay: 0.5s; }
.scroll-delay-6 { transition-delay: 0.6s; }

/* ========== PARALLAX DECORATIONS ========== */
.intro-image-container {
    flex: 1;
    min-width: 400px;
    height: 450px;
    background: linear-gradient(135deg, #e0f2fe 0%, #dbeafe 100%);
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
    transition: var(--speed);
    position: relative;
    overflow: hidden;
    animation: fadeIn 0.6s ease 0.4s both;
}

.decoration-1 {
    width: 280px;
    height: 280px;
    background: rgba(0, 151, 178, 0.08);
    top: -60px;
    right: -60px;
    transition: transform 0.3s ease-out;
}

.decoration-2 {
    width: 200px;
    height: 200px;
    background: rgba(0, 210, 106, 0.08);
    bottom: -40px;
    left: -40px;
    transition: transform 0.3s ease-out;
}

.intro-image-container:hover .decoration-1 {
    transform: translate(15px, -15px) scale(1.1);
}

.intro-image-container:hover .decoration-2 {
    transform: translate(-15px, 15px) scale(1.1);
}

/* ========== FREE BADGE ========== */
.free-badge {
    position: absolute;
    top: 20px;
    right: 20px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, var(--green), var(--green-dark));
    color: var(--white);
    padding: 10px 20px;
    border-radius: var(--radius-full);
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 4px 15px rgba(0, 210, 106, 0.3);
    z-index: 10;
    animation: badgePulse 2s ease-in-out infinite;
}

.free-badge svg {
    width: 18px;
    height: 18px;
}

@keyframes badgePulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
}

.bg-decoration {
    position: absolute;
    border-radius: 50%;
}

/* ========== FEATURES SECTION ========== */
.features-section {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 50px 8% 30px;
}

.features-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    animation: fadeIn 0.6s ease 0.5s both;
}

.feature-item {
    display: flex;
    align-items: center;
    gap: 14px;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    padding: 16px 20px;
    border-radius: var(--radius-lg);
    color: var(--gray-dark);
    font-size: 14px;
    font-weight: 600;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    transition: all var(--speed) ease;
    border: 1px solid rgba(226, 232, 240, 0.6);
}

.feature-item:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 20px 40px rgba(0, 151, 178, 0.15);
    border-color: var(--primary);
    background: rgba(255, 255, 255, 0.95);
}

.feature-icon {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    flex-shrink: 0;
}

.feature-icon .icon-svg {
    width: 16px;
    height: 16px;
    stroke-width: 2.5;
}

.feature-icon:hover .icon-svg {
    transform: scale(1.1) rotate(5deg);
}

/* ========== FOOTER ========== */
.footer {
    padding: 24px 8%;
    text-align: center;
    border-top: 1px solid var(--border);
    color: var(--gray-dark);
    font-size: 13px;
    /* background: linear-gradient(180deg, var(--gray-light) 0%, #f5f7fa 100%); */
    margin-top: auto;
    background-color:var(--gray-light);
}

.footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    max-width: 600px;
    margin: 0 auto;
}

.social-links {
    margin: 25px 0px;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    justify-content: center;
}

.social-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--gray-dark);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    border-radius: var(--radius-lg);
    padding: 8px 17px;
    transition: all var(--speed) ease;
    white-space: nowrap;
    /* background-color: var(--primary-dark); */
}

.social-link .feature-icon {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
}

.social-link .feature-icon .icon-svg {
    width: 20px;
    height: 20px;
    stroke-width: 2.5;
}

.social-link:hover {
    color: var(--primary);
    transform: translateY(-1px);
    box-shadow: var(--shadow);
}

.social-icon {
    width: 18px;
    height: 18px;
}

/* ========== ANIMATIONS ========== */
@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ========== RESPONSIVE ========== */
@media (max-width: 1024px) {
    .main-content {
        padding: 30px 40px 20px;
        gap: 40px;
    }
    
    .intro-image-container {
        min-width: 100%;
        height: 380px;
    }
    
    .features-section {
        padding: 30px 40px 50px;
    }
}

@media (max-width: 768px) {
    .header {
        padding: 12px 16px;
    }
    
    .logo {
        width: 52px;
        height: 52px;
    }
    
    .logo img {
        max-height: 44px;
    }
    
    .site-name {
        font-size: 16px;
        margin-left: 12px;
    }
    
    .login {
        padding: 8px 24px;
        font-size: 13px;
    }
    
    .main-content {
        padding: 25px 20px 15px;
        flex-direction: column;
        gap: 30px;
        min-height: auto;
    }
    
    .intro-msg-container {
        min-width: 100%;
        text-align: center;
    }
    
    .intro-msg-container h1 {
        font-size: 32px;
    }
    
    .stats-container {
        justify-content: space-around;
        gap: 20px;
        flex-wrap: wrap;
    }
    
    .button-container {
        flex-direction: column;
        width: 100%;
    }
    
    .btn-primary {
        width: 100%;
        justify-content: center;
    }
    
    .intro-image-container {
        min-width: 100%;
        height: 320px;
    }
    
    .features-section {
        padding: 25px 20px 40px;
    }
    
    .features-list {
        grid-template-columns: 1fr;
        gap: 15px;
    }

    .feature-item {
        padding: 16px 20px;
    }
}

@media (max-width: 480px) {
    .intro-msg-container h1 {
        font-size: 38px;
    }
    
    .intro-image-container {
        height: 260px;
    }
    
    .main-content {
        padding: 16px 12px 20px;
        gap: 20px;
    }
    
    .stats-container {
        flex-direction: row;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: center;
    }
    
    .stat-number {
        font-size: 24px !important;
    }
    
    .stat-label {
        font-size: 11px !important;
    }
    
    .footer {
        padding: 12px 8px;
    }
    
    .social-links {
        gap: 8px;
    }
    
    html {
        font-size: 14px;
    }
}
